<%- include('partials/header') %>

<main class="membership-page">
    <!-- Section 1: Hero -->
    <section class="membership-hero">
        <div class="container">
            <h1>Membership</h1>
            <p class="text-muted">Unlock exclusive culinary experiences, masterclasses, and a private community of food enthusiasts.</p>
            <div class="mt-section">
                <a href="#pricing" class="btn btn-primary">Join Membership</a>
            </div>
        </div>
    </section>

    <div class="container">
        <!-- Section 2: Membership Plans -->
        <section id="pricing" class="mt-section">
            <h2 class="section-title text-center">Choose Your Plan</h2>
            <div class="plans-grid mt-section">
                
                <!-- Free Plan -->
                <div class="card plan-card">
                    <div class="card-body">
                        <h3>Free</h3>
                        <div class="plan-price">$0 <span>/month</span></div>
                        <p class="text-muted">Basic access to recipes</p>
                        <ul class="plan-features">
                            <li>Access to free recipes</li>
                            <li>Community forum (Read-only)</li>
                            <li>Basic weekly newsletter</li>
                        </ul>
                        <% if (!locals.user) { %>
                            <a href="/register" class="btn btn-outline btn-block">Sign Up Free</a>
                        <% } else if (locals.user.role === 'free') { %>
                            <button class="btn btn-outline btn-block" disabled style="opacity: 0.5; cursor: not-allowed;">Current Plan</button>
                        <% } else { %>
                            <button class="btn btn-outline btn-block" disabled style="opacity: 0.5; cursor: not-allowed;">Included</button>
                        <% } %>
                    </div>
                </div>

                <!-- Premium Plan -->
                <div class="card plan-card plan-premium">
                    <div class="card-body">
                        <h3>Premium</h3>
                        <div class="plan-price">$9.99 <span>/month</span></div>
                        <p class="text-muted">For aspiring home chefs</p>
                        <ul class="plan-features">
                            <li>All Free features</li>
                            <li>Unlock Premium recipes</li>
                            <li>Step-by-step video tutorials</li>
                            <li>Private community access</li>
                        </ul>
                        <% if (!locals.user) { %>
                            <a href="/login?redirect=/membership" class="btn btn-primary btn-block">Login to Upgrade</a>
                        <% } else if (locals.user.role === 'premium') { %>
                            <button class="btn btn-primary btn-block" disabled style="opacity: 0.5; cursor: not-allowed;">Current Plan</button>
                        <% } else if (locals.user.role === 'vip' || locals.user.role === 'admin') { %>
                            <button class="btn btn-primary btn-block" disabled style="opacity: 0.5; cursor: not-allowed;">Included in your plan</button>
                        <% } else { %>
                            <a href="/membership/checkout?plan=premium" class="btn btn-primary btn-block">Get Premium</a>
                        <% } %>
                    </div>
                </div>

                <!-- VIP Plan -->
                <div class="card plan-card">
                    <div class="card-body">
                        <h3>VIP</h3>
                        <div class="plan-price">$24.99 <span>/month</span></div>
                        <p class="text-muted">The ultimate culinary journey</p>
                        <ul class="plan-features">
                            <li>All Premium features</li>
                            <li>1-on-1 Q&A with Chef James</li>
                            <li>Exclusive Masterclass courses</li>
                            <li>Downloadable resources</li>
                        </ul>
                        <% if (!locals.user) { %>
                            <a href="/login?redirect=/membership" class="btn btn-outline btn-block">Login to Upgrade</a>
                        <% } else if (locals.user.role === 'vip') { %>
                            <button class="btn btn-outline btn-block" disabled style="opacity: 0.5; cursor: not-allowed;">Current Plan</button>
                        <% } else if (locals.user.role === 'admin') { %>
                            <button class="btn btn-outline btn-block" disabled style="opacity: 0.5; cursor: not-allowed;">Included in Admin</button>
                        <% } else { %>
                            <a href="/membership/checkout?plan=vip" class="btn btn-outline btn-block">Get VIP</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 3: Call To Action -->
        <section class="cta-banner mt-section" style="margin-bottom: 60px;">
            <h2 class="section-title">Ready to elevate your cooking?</h2>
            <p>Join thousands of members mastering the art of fine dining.</p>
            <div class="mt-15">
                <% if (!locals.user) { %>
                    <a href="/register" class="btn btn-outline">Join Membership Now</a>
                <% } else { %>
                    <a href="#pricing" class="btn btn-outline">Review Plans</a>
                <% } %>
            </div>
        </section>
    </div>
</main>

<%- include('partials/footer') %>