<!-- src/views/contests.ejs -->
<%- include('partials/header') %>

<main class="contests-page">
    <!-- Section 1: Hero -->
    <section class="contests-hero text-center mt-section">
        <div class="container">
            <h1>Upcoming Cooking Contests</h1>
            <p class="text-muted">Test your skills, compete with the best, and win amazing prizes.</p>
            <div class="mt-15">
                <a href="#upcoming" class="btn btn-primary">Browse Competitions</a>
            </div>
        </div>
    </section>

    <!-- Section 2: Featured Contest -->
    <section class="container mt-section">
        <h2 class="section-title">Featured Contest</h2>
        <div class="card featured-contest-card">
            <div class="image-placeholder featured-img">
                <span>IMAGE PLACEHOLDER</span>
            </div>
            <div class="card-body p-40">
                <h3>Master Chef 2026 Championship</h3>
                <p class="text-muted mt-15">The ultimate test of culinary excellence. Prepare a three-course meal for our panel of expert judges and prove you have what it takes to be a master.</p>
                <ul class="contest-details mt-15">
                    <li><strong>Deadline:</strong> August 15, 2026</li>
                    <li><strong>Event Date:</strong> September 1, 2026</li>
                    <li><strong>Prize:</strong> $10,000 + VIP Membership</li>
                </ul>
                <div class="mt-15">
                    <!-- SỬA: Đổi từ /register sang trang Detail thực tế -->
                    <a href="/contests/detail/master-chef-2026-championship" class="btn btn-primary">View & Join Contest</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Section 3: Contest Categories -->
    <section class="container mt-section">
        <h2 class="section-title text-center">Contest Categories</h2>
        <div class="categories-grid mt-section">
            <div class="card text-center p-20"><div class="card-body"><h3>Live Competition</h3></div></div>
            <div class="card text-center p-20"><div class="card-body"><h3>Online Challenge</h3></div></div>
            <div class="card text-center p-20"><div class="card-body"><h3>Community Event</h3></div></div>
            <div class="card text-center p-20"><div class="card-body"><h3>Premium Contest</h3></div></div>
        </div>
    </section>

    <!-- Section 4: Upcoming Contests Grid -->
    <section id="upcoming" class="container mt-section">
        <h2 class="section-title text-center">Upcoming Contests</h2>
        <div class="contests-grid mt-section">
            <!-- Card 1 -->
            <div class="card contest-card">
                <div class="image-placeholder card-img"><span>IMAGE PLACEHOLDER</span></div>
                <div class="card-body">
                    <h3>The Great Baking Showdown</h3>
                    <p class="text-muted">Show off your best pastry skills in this high-stakes baking competition.</p>
                    <div class="recipe-meta flex-row mt-15">
                        <span class="badge">Hard</span>
                        <span class="meta-text font-bold">Prize: $5,000</span>
                    </div>
                    <p class="text-sm mt-15"><strong>Deadline:</strong> July 25, 2026</p>
                </div>
                <div class="card-footer flex-between">
                    <!-- SỬA: Trỏ về đúng đường dẫn Detail -->
                    <a href="/contests/detail/the-great-baking-showdown" class="btn btn-primary btn-sm">Join</a>
                    <a href="/contests/detail/the-great-baking-showdown" class="btn btn-outline btn-sm">Details</a>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="card contest-card">
                <div class="image-placeholder card-img"><span>IMAGE PLACEHOLDER</span></div>
                <div class="card-body">
                    <h3>Vegan Innovation Challenge</h3>
                    <p class="text-muted">Create a mind-blowing plant-based dish that completely redefines vegan cuisine.</p>
                    <div class="recipe-meta flex-row mt-15">
                        <span class="badge">Medium</span>
                        <span class="meta-text font-bold">Prize: Kitchen Set</span>
                    </div>
                    <p class="text-sm mt-15"><strong>Deadline:</strong> August 02, 2026</p>
                </div>
                <div class="card-footer flex-between">
                    <a href="/contests/detail/vegan-innovation-challenge" class="btn btn-primary btn-sm">Join</a>
                    <a href="/contests/detail/vegan-innovation-challenge" class="btn btn-outline btn-sm">Details</a>
                </div>
            </div>
            
            <!-- (Thêm các Card khác tương tự...) -->
        </div>
        
        <!-- Nút Xem Tất Cả trỏ sang File Số 7 (Danh Sách Đầy Đủ) -->
        <div class="text-center mt-section">
            <a href="/contests/list" class="btn btn-primary">View All Contests</a>
        </div>
    </section>

    <!-- Sections 6 & 7: Tóm tắt Rules & FAQ -->
    <section class="container mt-section">
        <div class="grid-2-col">
            <!-- Tóm tắt Rules -->
            <div>
                <h2 class="section-title">Contest Rules</h2>
                <p class="text-muted mb-15">Review our standard rules for eligibility, submission guidelines, and judging criteria before entering.</p>
                <!-- SỬA: Thêm nút trỏ tới trang Rules (File số 10) -->
                <a href="/contests/rules" class="btn btn-outline">Read Full Rules</a>
            </div>

            <!-- Tóm tắt FAQ -->
            <div>
                <h2 class="section-title">FAQ</h2>
                <p class="text-muted mb-15">Have questions about prize claims, multiple entries, or deadlines? We've got answers.</p>
                <!-- SỬA: Thêm nút trỏ tới trang FAQ (File số 9) -->
                <a href="/contests/faq" class="btn btn-outline">Visit FAQ Page</a>
            </div>
        </div>
    </section>

    <!-- Section 8: Bottom CTA -->
    <section class="container mt-section mb-section">
        <div class="cta-banner">
            <h2 class="section-title">See our hall of fame.</h2>
            <div class="mt-15">
                <!-- SỬA: Dẫn tới trang Winners (File số 11) -->
                <a href="/contests/winners" class="btn btn-outline">View Past Winners</a>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>