<%- include('partials/header') %>

<main class="container mt-section recipes-page">
    <!-- Section 1: Header -->
    <section class="recipes-header text-center">
        <h1 class="section-title">Free Recipes Gallery</h1>
        <p class="text-muted" style="max-width: 600px; margin: 0 auto;">Explore our collection of culinary delights. High-quality, tested recipes accessible to everyone.</p>
    </section>

    <!-- Section 2: Filters & Search (Nâng cấp UI, giữ nguyên ID) -->
    <section class="recipes-filters-premium mt-30">
        <!-- Thanh tìm kiếm to, rõ ràng -->
        <div class="filter-search-bar">
            <input type="text" id="recipeSearchInput" class="form-input search-premium" placeholder="Search recipes, ingredients, or chefs...">
        </div>
        
        <div class="filter-controls-row mt-15 flex-between">
            <!-- Nút danh mục -->
            <div id="categoryFilterGroup" class="filter-categories gap-buttons">
                <button class="btn btn-primary btn-sm category-pill active" data-category="ALL">ALL</button>
                <button class="btn btn-outline btn-sm category-pill" data-category="APPETIZERS">APPETIZERS</button>
                <button class="btn btn-outline btn-sm category-pill" data-category="MAINS">MAINS</button>
                <button class="btn btn-outline btn-sm category-pill" data-category="DESSERTS">DESSERTS</button>
                <button class="btn btn-outline btn-sm category-pill" data-category="VEGAN">VEGAN</button>
            </div>

            <!-- Dropdown -->
            <div class="filter-dropdowns gap-buttons">
                <select id="difficultyFilter" class="form-input select-premium">
                    <option value="">Any Difficulty</option>
                    <option value="easy">Easy</option>
                    <option value="medium">Medium</option>
                    <option value="hard">Hard</option>
                </select>
                <select id="sortFilter" class="form-input select-premium">
                    <option value="newest">Sort By: Newest</option>
                    <option value="popular">Sort By: Popular</option>
                </select>
            </div>
        </div>
    </section>
    
    <div class="divider mt-30"></div>

    <!-- Section 3: Recipe Grid (ID giữ nguyên cho JS) -->
    <section id="recipesGridContainer" class="recipes-grid mt-30">
        <p class="text-muted text-center w-100" style="grid-column: 1/-1;">Gathering culinary formulas...</p>
    </section>

    <!-- Section 4: Pagination (ID giữ nguyên) -->
    <section id="paginationWrapper" class="pagination-wrapper mt-section flex-center">
        <!-- JS vẽ phân trang -->
    </section>
</main>

<script src="/js/recipes.js"></script>

<%- include('partials/footer') %>