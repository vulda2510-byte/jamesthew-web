<!-- src/views/login.ejs -->
<%- include('partials/header') %>

<main class="login-wrapper">
    <div class="card login-card">
        <div class="login-header">
            <h1 class="login-title">Welcome Back</h1>
        </div>
        
        <!-- Vùng hiển thị thông báo lỗi/thành công -->
        <div id="alertMessage" style="display: none; padding: 10px; margin-bottom: 15px; border-radius: 4px; text-align: center;"></div>
        
        <form id="loginForm">
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="Enter your email" required>
            </div>
            
            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password" name="password" class="form-input" placeholder="Enter your password" required>
            </div>
            
            <div class="login-options">
                <label class="form-checkbox-group">
                    <input type="checkbox" name="rememberMe" id="rememberMe">
                    <span>Remember Me</span>
                </label>
                <a href="#" class="text-link">Forgot Password?</a>
            </div>
            
            <button type="submit" id="btnSubmit" class="btn btn-primary btn-block">Login</button>
        </form>
        
        <div class="divider"></div>
        
        <div class="login-footer">
            <span>Don't have an account?</span>
            <a href="/register" class="text-link">Register</a>
        </div>
    </div>
</main>

<!-- Nhúng file JS xử lý logic cho trang đăng nhập -->
<script src="/js/login.js"></script>

<%- include('partials/footer') %>