<%- include('partials/header') %>
<link rel="stylesheet" href="/css/profile.css">
<!-- Chèn vào trong thẻ <head> của header.ejs -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="profile-banner"></div>

<main class="container profile-main-container mb-5" style="max-width: 1100px;">
    
    <!-- Header Profile Card -->
    <div class="card shadow-sm border-0 rounded-4 mb-4 profile-header-card">
        <div class="card-body p-4 p-md-5 d-flex flex-column flex-md-row align-items-md-center justify-content-between">
            <div class="d-flex align-items-center gap-4 mb-4 mb-md-0">
                <div class="profile-avatar">
                    <%= user && user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                </div>
                <div>
                    <h2 class="fw-bold mb-1 d-flex align-items-center gap-2">
                        <%= user ? (user.firstName + ' ' + user.lastName) : 'Chef Member' %>
                        
                        <!-- Dynamically Badge based on Role -->
                        <% if (user && user.role === 'admin') { %>
                            <span class="badge bg-danger text-white fs-6 px-3 py-1 rounded-pill shadow-sm">Administrator</span>
                        <% } else if (user && user.role === 'vip') { %>
                            <span class="badge bg-dark text-warning border border-warning fs-6 px-3 py-1 rounded-pill shadow-sm">VIP Member</span>
                        <% } else if (user && user.role === 'premium') { %>
                            <span class="badge bg-warning text-dark fs-6 px-3 py-1 rounded-pill shadow-sm">Premium Member</span>
                        <% } else { %>
                            <span class="badge bg-secondary text-white fs-6 px-3 py-1 rounded-pill shadow-sm">Free Member</span>
                        <% } %>
                    </h2>
                    <p class="text-muted mb-0 fs-6">@<%= user ? user.username : 'unknown' %></p>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-2">
                <% if (user && user.role === 'admin') { %>
                    <a href="/admin/dashboard" class="btn btn-danger rounded-pill px-4 py-2 fw-bold shadow-sm d-inline-flex align-items-center gap-2">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        Admin Portal
                    </a>
                <% } else if (user && user.role === 'free') { %>
                    <a href="/membership" class="btn btn-dark rounded-pill px-4 py-2 fw-bold shadow-sm">Upgrade Plan</a>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Layout 2 cột: Navigation Sidebar & Content Tab -->
    <div class="row g-4">
        <!-- Sidebar Left -->
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 sticky-top" style="top: 20px;">
                <div class="card-body p-3">
                    <div class="nav flex-column nav-pills gap-2" id="v-pills-tab" role="tablist">
                        <button class="nav-link active text-start fw-bold py-3 px-4 d-flex align-items-center gap-3" data-bs-toggle="pill" data-bs-target="#public-profile" type="button" role="tab">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            View Profile
                        </button>
                        <button class="nav-link text-start fw-bold py-3 px-4 d-flex align-items-center gap-3" data-bs-toggle="pill" data-bs-target="#account-settings" type="button" role="tab">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            Account Settings
                        </button>
                        <button class="nav-link text-start fw-bold py-3 px-4 d-flex align-items-center gap-3" data-bs-toggle="pill" data-bs-target="#security-settings" type="button" role="tab">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            Security & Password
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Content Right -->
        <div class="col-12 col-lg-8">
            <div id="alertBox" class="alert d-none rounded-4 border-0 shadow-sm mb-4"></div>

            <div class="tab-content" id="v-pills-tabContent">
                
                <!-- TAB 1: VIEW PROFILE -->
                <div class="tab-pane fade show active" id="public-profile" role="tabpanel">
                    
                    <!-- Role-Based Dynamic Banner -->
                    <% if (user && user.role === 'free') { %>
                        <div class="role-banner banner-free rounded-4 p-4 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="fw-bold mb-1">Unlock Culinary Culinary Masterpieces</h5>
                                    <p class="mb-0 text-muted small">Upgrade to Premium or VIP to access exclusive chef recipes & private masterclasses.</p>
                                </div>
                                <a href="/membership" class="btn btn-dark btn-sm rounded-pill px-4 fw-bold text-nowrap ms-3">Explore Plans</a>
                            </div>
                        </div>
                    <% } else if (user && user.role === 'premium') { %>
                        <div class="role-banner banner-premium rounded-4 p-4 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="fw-bold mb-1 text-dark">Premium Access Active</h5>
                                    <p class="mb-0 text-secondary small">You have unlimited access to premium recipe collection.</p>
                                </div>
                                <a href="/recipes/premium-exclusive" class="btn btn-outline-dark btn-sm rounded-pill px-4 fw-bold text-nowrap ms-3">Exclusive Recipes</a>
                            </div>
                        </div>
                    <% } else if (user && user.role === 'vip') { %>
                        <div class="role-banner banner-vip rounded-4 p-4 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="fw-bold mb-1 text-warning">VIP Privilege Activated</h5>
                                    <p class="mb-0 text-light small">Enjoy 1-on-1 Masterclass support and all premium features.</p>
                                </div>
                                <a href="/vip-masterclass" class="btn btn-warning btn-sm rounded-pill px-4 fw-bold text-nowrap ms-3">Join Masterclass</a>
                            </div>
                        </div>
                    <% } else if (user && user.role === 'admin') { %>
                        <div class="role-banner banner-admin rounded-4 p-4 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="fw-bold mb-1 text-danger">System Administrator</h5>
                                    <p class="mb-0 text-muted small">Full system access privileges granted.</p>
                                </div>
                                <a href="/admin/dashboard" class="btn btn-danger btn-sm rounded-pill px-4 fw-bold text-nowrap ms-3">Dashboard</a>
                            </div>
                        </div>
                    <% } %>

                    <!-- Bio Card -->
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-body p-4 p-md-5">
                            <h4 class="fw-bold mb-4">About Me</h4>
                            <p class="text-muted fs-6 mb-4"><%= user && user.bio ? user.bio : 'No biography provided yet.' %></p>
                            <hr class="my-4">
                            <div class="row g-3">
                                <div class="col-6">
                                    <h6 class="text-muted small fw-bold text-uppercase">Cooking Style</h6>
                                    <p class="fw-bold fs-6 mb-0"><%= user && user.cookingStyle ? user.cookingStyle : 'Modern Gastronomy' %></p>
                                </div>
                                <div class="col-6">
                                    <h6 class="text-muted small fw-bold text-uppercase">Location</h6>
                                    <p class="fw-bold fs-6 mb-0"><%= user && user.location ? user.location : 'Hanoi, Vietnam' %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TAB 2: ACCOUNT SETTINGS -->
                <div class="tab-pane fade" id="account-settings" role="tabpanel">
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-body p-4 p-md-5">
                            <h4 class="fw-bold mb-4">Account Settings</h4>
                            <form id="formUpdateProfile">
                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-uppercase">First Name</label>
                                        <input type="text" name="firstName" class="form-control bg-light border-0 py-2 px-3 rounded-3" value="<%= user ? user.firstName : '' %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-uppercase">Last Name</label>
                                        <input type="text" name="lastName" class="form-control bg-light border-0 py-2 px-3 rounded-3" value="<%= user ? user.lastName : '' %>" required>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label fw-bold small text-uppercase">Biography</label>
                                        <textarea name="bio" rows="3" class="form-control bg-light border-0 py-2 px-3 rounded-3"><%= user ? user.bio : '' %></textarea>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-dark px-5 py-2 rounded-pill fw-bold">Save Changes</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- TAB 3: CHANGE PASSWORD -->
                <div class="tab-pane fade" id="security-settings" role="tabpanel">
                     <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-body p-4 p-md-5">
                            <h4 class="fw-bold mb-4">Change Password</h4>
                            <form id="formChangePassword">
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-uppercase">New Password</label>
                                    <input type="password" name="newPassword" class="form-control bg-light border-0 py-2 px-3 rounded-3" required>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-uppercase">Confirm New Password</label>
                                    <input type="password" name="confirmNewPassword" class="form-control bg-light border-0 py-2 px-3 rounded-3" required>
                                </div>
                                <button type="submit" class="btn btn-dark px-5 py-2 rounded-pill fw-bold">Update Password</button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>

<script src="/js/profile.js"></script>
<%- include('partials/footer') %>