<%- include('partials/header') %>
<link rel="stylesheet" href="/css/recipe-detail.css">

<main class="container mt-section recipe-detail-page">
    <!-- Section 1: Breadcrumb -->
    <nav class="breadcrumb premium-breadcrumb">
        <a href="/">Home</a> <span>/</span> 
        <a href="/recipes">Recipes</a> <span>/</span> 
        <span id="breadcrumbCurrent" class="text-muted">Loading...</span>
    </nav>

    <!-- Section 2: Recipe Hero -->
    <section class="recipe-hero mt-30">
        <div class="recipe-hero-image">
            <div class="image-placeholder premium-image-box">
                <span id="recipeHeroImageLabel" class="text-muted">Loading Media...</span>
            </div>
        </div>
        <div class="recipe-hero-info">
            <div class="recipe-meta flex-row mt-10">
                <span id="recipeCategory" class="category-label text-muted">...</span>
                <span class="meta-dot">•</span>
                <span id="recipeDuration" class="meta-text">...</span>
                <span class="meta-dot">•</span>
                <span id="recipeBadge" class="badge premium-badge">...</span>
            </div>
            
            <h1 id="recipeTitle" class="recipe-title premium-title">Loading Recipe Title...</h1>
            <p id="recipeDescription" class="recipe-description text-muted">...</p>
            
            <div class="gap-buttons action-buttons mt-30">
                <button id="btnSaveRecipe" class="btn btn-outline btn-premium-action">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                    Save Recipe
                </button>
                <button id="btnShareRecipe" class="btn btn-outline btn-premium-action">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"></path></svg>
                    Share
                </button>
            </div>
        </div>
    </section>

    <div class="divider mt-section"></div>

    <!-- Section 3: Recipe Stats Bar (Thay Emoji bằng SVG) -->
    <section class="recipe-stats-bar mt-30">
        <div class="stat-box text-center">
            <span class="stat-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <strong>Prep Time</strong>
            <p id="statPrepTime" class="text-muted">--</p>
        </div>
        <div class="stat-box text-center">
            <span class="stat-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path></svg></span>
            <strong>Cook Time</strong>
            <p id="statCookTime" class="text-muted">--</p>
        </div>
        <div class="stat-box text-center">
            <span class="stat-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg></span>
            <strong>Servings</strong>
            <p id="statServings" class="text-muted">--</p>
        </div>
        <div class="stat-box text-center">
            <span class="stat-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg></span>
            <strong>Calories</strong>
            <p id="statCalories" class="text-muted">--</p>
        </div>
        <div class="stat-box text-center">
            <span class="stat-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg></span>
            <strong>Difficulty</strong>
            <p id="statDifficulty" class="text-muted">--</p>
        </div>
        <div class="stat-box text-center">
            <span class="stat-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <strong>Cuisine</strong>
            <p id="statCuisine" class="text-muted">--</p>
        </div>
    </section>

    <!-- Section 4: Content Grid (Đã đồng bộ giao diện 2 cột) -->
    <div class="recipe-content-grid mt-section">
        <!-- Left Column: Ingredients -->
        <div class="recipe-ingredients premium-box">
            <h2 class="section-title text-center" style="font-size: 1.8rem;">INGREDIENTS</h2>
            <div id="ingredientsListContainer" class="ingredient-list mt-15">
                <p class="text-muted text-center">Processing ingredients list...</p>
            </div>
        </div>

        <!-- Right Column: Instructions (THÊM class premium-box để đồng bộ) -->
        <div class="recipe-instructions premium-box">
            <h2 class="section-title text-center" style="font-size: 1.8rem;">INSTRUCTIONS</h2>
            <div id="instructionsListContainer" class="instructions-list mt-15">
                <p class="text-muted text-center">Arranging steps...</p>
            </div>
        </div>
    </div>

    <div class="divider mt-section"></div>

    <!-- Section 5: Chef Information (Thiết kế lại canh giữa) -->
    <section class="chef-section mt-30 premium-chef-box text-center">
        <div class="avatar-placeholder premium-avatar">
            <span id="chefAvatarLabel">AV</span>
        </div>
        <div class="chef-info text-center">
            <h4 class="text-muted text-uppercase" style="font-size: 0.85rem; letter-spacing: 2px;">Recipe Created By</h4>
            <h3 id="chefName" class="chef-name">Chef Name</h3>
            <p id="chefBio" class="text-muted mt-10" style="margin-left: auto; margin-right: auto; max-width: 600px; line-height: 1.6;">Chef biography information.</p>
            <a id="chefProfileLink" href="/profile" class="btn btn-outline btn-sm mt-15 btn-premium-action">View Profile</a>
        </div>
    </section>

    <!-- Section 6: Related Recipes -->
    <section class="related-recipes mt-section">
        <h2 class="section-title text-center">Related Masterpieces</h2>
        <div id="relatedRecipesGrid" class="recipes-grid mt-30"></div>
    </section>
</main>

<script src="/js/recipe-detail.js"></script>
<%- include('partials/footer') %>