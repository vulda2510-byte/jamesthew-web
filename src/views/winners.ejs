<%- include('partials/header') %>
<link rel="stylesheet" href="/css/winners.css">
<main class="container my-5" style="max-width: 1000px;">
    <!-- Header Page -->
    <div class="text-center mb-5">
        <h2 class="fw-bold display-6 mb-3">🏆 Bảng Vinh Danh</h2>
        <p class="text-muted fs-5">Tôn vinh các đầu bếp xuất sắc nhất qua các mùa giải Cuisine</p>
    </div>

    <!-- Thanh Lọc Winner -->
    <div class="card border-0 shadow-sm p-4 mb-5 rounded-4 bg-light">
        <form id="winnerFilterForm" class="row g-3 align-items-center">
            <div class="col-12 col-md-4">
                <select name="year" class="form-select border-0 shadow-sm py-2 px-3 rounded-3">
                    <option value="">-- Lọc theo Năm --</option>
                    <option value="2026">Năm 2026</option>
                    <option value="2025">Năm 2025</option>
                </select>
            </div>
            <div class="col-12 col-md-5">
                <input type="text" name="contestName" class="form-control border-0 shadow-sm py-2 px-3 rounded-3" placeholder="Tìm kiếm theo tên cuộc thi...">
            </div>
            <div class="col-12 col-md-3">
                <button type="submit" class="btn btn-warning text-dark fw-bold w-100 py-2 shadow-sm rounded-pill">Tra Cứu</button>
            </div>
        </form>
    </div>

    <!-- Bảng hiển thị Winner -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-dark">
                    <tr>
                        <th class="py-3">Thứ Hạng</th>
                        <th class="py-3 text-start">Thành Viên</th>
                        <th class="py-3 text-start">Cuộc Thi</th>
                        <th class="py-3">Giải Thưởng</th>
                        <th class="py-3">Thời Gian</th>
                    </tr>
                </thead>
                <tbody id="winnersTableBody">
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <div class="spinner-border text-warning mb-3" role="status"></div>
                            <br>Đang tải dữ liệu...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</main>

<script>
    async function loadWinners() {
        const formData = new FormData(document.getElementById('winnerFilterForm'));
        const params = new URLSearchParams(formData).toString();
        const res = await fetch(`/api/v1/contests/winners/list?${params}`);
        const result = await res.json();
        const tbody = document.getElementById('winnersTableBody');

        if (result.success && result.data.length > 0) {
            tbody.innerHTML = result.data.map(w => {
                let rankBadge = '';
                if (w.rank === 1) rankBadge = '<span class="badge bg-warning text-dark fs-6 px-3 py-2 rounded-pill shadow-sm">🥇 Quán Quân</span>';
                else if (w.rank === 2) rankBadge = '<span class="badge bg-secondary fs-6 px-3 py-2 rounded-pill shadow-sm">🥈 Á Quân</span>';
                else if (w.rank === 3) rankBadge = '<span class="badge bg-danger fs-6 px-3 py-2 rounded-pill shadow-sm">🥉 Hạng 3</span>';
                else rankBadge = `<span class="badge bg-light text-dark border px-3 py-2 rounded-pill">Hạng ${w.rank}</span>`;

                return `
                    <tr>
                        <td class="py-3">${rankBadge}</td>
                        <td class="text-start fw-bold py-3">@${w.winner?.username || 'Thành viên'}</td>
                        <td class="text-start text-muted py-3">${w.contest?.title || 'N/A'}</td>
                        <td class="text-success fw-bold py-3">${w.prize || 'Cúp kỷ niệm'}</td>
                        <td class="py-3">${new Date(w.created_at).toLocaleDateString('vi-VN')}</td>
                    </tr>
                `;
            }).join('');
        } else {
            tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-5">Không tìm thấy dữ liệu người chiến thắng phù hợp.</td></tr>`;
        }
    }

    document.getElementById('winnerFilterForm').addEventListener('submit', (e) => {
        e.preventDefault();
        loadWinners();
    });

    loadWinners();
</script>
<script src="/js/winners.js"></script>
<%- include('partials/footer') %>